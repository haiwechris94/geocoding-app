# ===========================================
# Geocoding Application - Environment Variables
# Application de Géocodage - Variables d'Environnement
# ===========================================

# Server Configuration / Configuration du Serveur
PORT=5000
NODE_ENV=development

# ===========================================
# API Keys / Clés API
# ===========================================

# Google Maps Geocoding API
# Get your key at: https://console.cloud.google.com/
# Obtenez votre clé sur: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# GeoNames API (Free - requires registration)
# Register at: https://www.geonames.org/login
# Inscrivez-vous sur: https://www.geonames.org/login
GEONAMES_USERNAME=your_geonames_username_here

# OpenStreetMap Nominatim (Free - no key required, but set email for contact)
# Nominatim OpenStreetMap (Gratuit - pas de clé requise, mais définissez un email)
NOMINATIM_EMAIL=your_email@example.com

# HDX (Humanitarian Data Exchange) API
# Register at: https://data.humdata.org/
# Inscrivez-vous sur: https://data.humdata.org/
HDX_API_KEY=your_hdx_api_key_here

# OpenCage Geocoding API (Free tier: 2,500 requests/day)
# Register at: https://opencagedata.com/
# Inscrivez-vous sur: https://opencagedata.com/
# Good coverage for African countries, supports 50+ languages
OPENCAGE_API_KEY=your_opencage_api_key_here

# ===========================================
# Rate Limiting / Limitation de Débit
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# File Upload / Téléchargement de Fichiers
# ===========================================
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ===========================================
# CORS Configuration / Configuration CORS
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# Logging / Journalisation
# ===========================================
LOG_LEVEL=debug
